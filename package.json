    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  }
}
