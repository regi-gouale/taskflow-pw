{
  "name": "taskflow-pw",
  "version": "0.0.1",
  "module": "index.ts",
  "description": "Projet de tests end-to-end avec Playwright pour automatiser et valider les parcours de l'application Taskflow.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --headed",
    "test:ui-only": "playwright test --project=chromium",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:allure": "playwright test",
    "allure:generate": "allure generate ./allure-results -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:report": "bun run allure:generate && bun run allure:open",
    "test:debug": "PWDEBUG=1 playwright test",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "allure": "^3.14.0",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "playwright": "^1.61.1"
  }
}
